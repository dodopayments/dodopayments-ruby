module Dodopayments
  module Models
    type dispute_challenged_webhook_event =
      {
        business_id: String,
        data: Dodopayments::Dispute,
        timestamp: Time,
        type: :"dispute.challenged"
      }

    class DisputeChallengedWebhookEvent < Dodopayments::Internal::Type::BaseModel
      attr_accessor business_id: String

      attr_accessor data: Dodopayments::Dispute

      attr_accessor timestamp: Time

      attr_accessor type: :"dispute.challenged"

      def initialize: (
        business_id: String,
        data: Dodopayments::Dispute,
        timestamp: Time,
        ?type: :"dispute.challenged"
      ) -> void

      def to_hash: -> {
        business_id: String,
        data: Dodopayments::Dispute,
        timestamp: Time,
        type: :"dispute.challenged"
      }
    end
  end
end
