module Dodopayments
  module Models
    type subscription_failed_webhook_event =
      {
        business_id: String,
        data: Dodopayments::Subscription,
        timestamp: Time,
        type: :"subscription.failed"
      }

    class SubscriptionFailedWebhookEvent < Dodopayments::Internal::Type::BaseModel
      attr_accessor business_id: String

      attr_accessor data: Dodopayments::Subscription

      attr_accessor timestamp: Time

      attr_accessor type: :"subscription.failed"

      def initialize: (
        business_id: String,
        data: Dodopayments::Subscription,
        timestamp: Time,
        ?type: :"subscription.failed"
      ) -> void

      def to_hash: -> {
        business_id: String,
        data: Dodopayments::Subscription,
        timestamp: Time,
        type: :"subscription.failed"
      }
    end
  end
end
