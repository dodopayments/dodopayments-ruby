module Dodopayments
  module Models
    type dispute_expired_webhook_event =
      {
        business_id: String,
        data: Dodopayments::Dispute,
        timestamp: Time,
        type: :"dispute.expired"
      }

    class DisputeExpiredWebhookEvent < Dodopayments::Internal::Type::BaseModel
      attr_accessor business_id: String

      attr_accessor data: Dodopayments::Dispute

      attr_accessor timestamp: Time

      attr_accessor type: :"dispute.expired"

      def initialize: (
        business_id: String,
        data: Dodopayments::Dispute,
        timestamp: Time,
        ?type: :"dispute.expired"
      ) -> void

      def to_hash: -> {
        business_id: String,
        data: Dodopayments::Dispute,
        timestamp: Time,
        type: :"dispute.expired"
      }
    end
  end
end
